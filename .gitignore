# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Local databases and runtime data directories (auto-created on run)
data/
output/
temp_uploads/

# Auto-generated visualization libraries by pyvis
lib/

# Virtual environments
venv/
.venv/
env/
.env

# OS-specific files
.DS_Store
Thumbs.db

# Project documentation / submission files (local only)
*.docx
*.xlsx
*.pdf

# Ignore all markdown files except README.md
*.md
!README.md
